# テスト環境用の環境変数テンプレート
# このファイルをコピーして .env.test を作成し、値を設定してください。
# cp .env.test.example .env.test

# ─── pytest 用（postgres-test / minio-test / api-test）────────────────
TEST_POSTGRES_USER=
TEST_POSTGRES_PASSWORD=
TEST_POSTGRES_DB=

TEST_MINIO_USER=
TEST_MINIO_PASSWORD=

# ─── E2E 用（postgres-e2e / minio-e2e / api-server-test / clip-worker-e2e）
E2E_POSTGRES_USER=
E2E_POSTGRES_PASSWORD=
E2E_POSTGRES_DB=

E2E_MINIO_USER=
E2E_MINIO_PASSWORD=
