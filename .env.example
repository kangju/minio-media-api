MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=media
DATABASE_URL=postgresql://mediauser:mediapassword@postgres:5432/mediadb
POSTGRES_USER=mediauser
POSTGRES_PASSWORD=mediapassword
POSTGRES_DB=mediadb
CLIP_SCORE_THRESHOLD=0.2
CLIP_TOP_K=10
MAX_FILE_SIZE_MB=500
PAGINATION_DEFAULT_LIMIT=30
PAGINATION_MAX_LIMIT=100
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
